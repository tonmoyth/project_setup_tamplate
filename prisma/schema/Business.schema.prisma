model Business {
  id String @id @default(uuid())

  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name        String
  description String?

  address   String
  latitude  Float
  longitude Float

  amenities String[]
  photos    String[]

  status BusinessStatus @default(PENDING_APPROVAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  announcements    Announcement[]
  attendances      Attendance[]
  staff            BusinessStaff[]
  chatThreads      ChatThread[]
  classSchedules   ClassSchedule[]
  dietPlans        DietPlan[]
  equipment        Equipment[]
  favorites        Favorite[]
  jobPosts         JobPost[]
  memberReferrals  MemberReferral[]
  referralSetting  MemberReferralSetting?
  memberships      Membership[]
  membershipPlans  MembershipPlan[]
  subscription     PlatformSubscription?
  qrCode           AttendanceQrCode?
  reviews          Review[]
  trainers         TrainerBusiness[]
  trainerPayouts   TrainerPayout[]
  businessReferral BusinessReferral?      @relation("ReferredBusiness")

  @@index([status])
  @@index([createdAt])
  @@index([latitude, longitude])
}
