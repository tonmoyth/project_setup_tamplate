model TrainerSpecialization {
  id String @id @default(uuid())

  trainerId String
  trainer   TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  tagId String
  tag   SpecializationTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([trainerId, tagId])
  @@index([trainerId])
  @@index([tagId])
}
